# ─────────────────────────────────────────────────────────────────────────────
# Spring Profiles
# Combine profiles with commas: e.g. preprod,h2  or  mainnet,postgres
#   Network:    preprod | mainnet
#   Database:   h2 (in-memory, dev) | postgres (production)
# ─────────────────────────────────────────────────────────────────────────────
SPRING_ACTIVE_PROFILES=preprod,h2

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
# PORT=9090
# MANAGEMENT_PORT=9091
# LOG_LEVEL=INFO
# LOG_FILE=./logs/uverify.log
CORS_ALLOWED_ORIGINS=*

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS_PER_MINUTE=20

# ─────────────────────────────────────────────────────────────────────────────
# Database (only needed for the postgres profile)
# ─────────────────────────────────────────────────────────────────────────────
# DB_URL=jdbc:postgresql://localhost:5432/uverify
# DB_USERNAME=uverify
# DB_PASSWORD=secret

# ─────────────────────────────────────────────────────────────────────────────
# Cardano — Primary Backend Service
# CARDANO_BACKEND_TYPE: blockfrost | koios
# ─────────────────────────────────────────────────────────────────────────────
CARDANO_BACKEND_TYPE=blockfrost
CARDANO_NETWORK=PREPROD

BLOCKFROST_BASE_URL=https://cardano-preprod.blockfrost.io/api/v0/
BLOCKFROST_PROJECT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Cardano — Secondary Query Backend (optional)
# When set, UTXO queries use this endpoint instead of the primary backend.
# Useful when the primary backend (e.g. Blockfrost) lags behind the indexer.
# A Blockfrost-compatible relay such as Yano works here.
# ─────────────────────────────────────────────────────────────────────────────
# CARDANO_QUERY_BASE_URL=http://localhost:8080
# CARDANO_QUERY_PROJECT_ID=localtest

# ─────────────────────────────────────────────────────────────────────────────
# Cardano — Wallets
# SERVICE_USER_ADDRESS defaults to the canonical preprod/mainnet address.
# Override only if you are running your own deployment.
# ─────────────────────────────────────────────────────────────────────────────
# SERVICE_USER_ADDRESS=addr_test1...
FACILITATOR_ACCOUNT_MNEMONIC=word1 word2 ... word24

# ─────────────────────────────────────────────────────────────────────────────
# Yaci Store — Blockchain Indexer
# Defaults point to public relay nodes; override to use your own node.
# ─────────────────────────────────────────────────────────────────────────────
# REMOTE_NODE_URL=preprod-node.world.dev.cardano.org
# REMOTE_NODE_PORT=30000

# ─────────────────────────────────────────────────────────────────────────────
# Faucet (testnet / local development only)
# ─────────────────────────────────────────────────────────────────────────────
# FAUCET_ENABLED=false
# FAUCET_MNEMONIC=word1 word2 ... word24
# FAUCET_UTXO_COUNT=3
# FAUCET_UTXO_AMOUNT_LOVELACE=10000000
# FAUCET_COOLDOWN_MS=120000

# ─────────────────────────────────────────────────────────────────────────────
# KERI / vLEI Credential Verification (optional)
# When set, the backend verifies KERI credentials against a live vLEI verifier.
# Without this, stored keri_verified values are used as-is.
# ─────────────────────────────────────────────────────────────────────────────
# VLEI_VERIFIER_URL=https://verifier.example.com
# KERIA_TIMEOUT_MS=3000

# ─────────────────────────────────────────────────────────────────────────────
# Extensions
# ─────────────────────────────────────────────────────────────────────────────

# Tokenizable Certificate — issues CIP-68 NFT pairs for redeemable certificates
# TOKENIZABLE_CERTIFICATE_EXTENSION_ENABLED=false

# Fractionized Certificate — splits certificates into fractional NFT holdings
# FRACTIONIZED_CERTIFICATE_EXTENSION_ENABLED=false

# Connected Goods — encrypted social hub for physical product identity
CONNECTED_GOODS_EXTENSION_ENABLED=false
# CONNECTED_GOODS_SERVICE_WALLET_ADDRESS=addr_test1...
# CONNECTED_GOODS_ENCRYPTION_SALT=

# Tadamon — community service organisation management via Google Sheets
# TADAMON_EXTENSION_ENABLED=false
# TADAMON_ALLOWED_ADDRESSES=addr1,addr2
# TADAMON_GOOGLE_SHEETS_ID=
# TADAMON_GOOGLE_SHEETS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# TADAMON_GOOGLE_SHEETS_SERVICE_ACCOUNT=account@project.iam.gserviceaccount.com
